    "--status-ended": "#464653",
    "--border": "#908f9e",
    "--input": "#0c0f0f",
    "--ring": "#bfc2ff",
    "--primary": "#bfc2ff",
    "--primary-foreground": "#181d8c",
    "--secondary": "#af8d11",
    "--secondary-foreground": "#342800",
    "--card": "#1e2020",
    "--card-foreground": "#ffffff",
