{
  "id": "final-fantasy",
  "name": "Final Fantasy",
  "author": "agent-zoo",
  "tokens": {
    "--bg": "#000000",
    "--fg": "#ffffff",
    "--muted": "#0c0f0f",
    "--muted-foreground": "#c6c5d5",
    "--accent": "#ffffff",
    "--accent-foreground": "#000080",
    "--accent-2": "#c6c6c7",
    "--status-running": "#43b047",
    "--status-waiting": "#e9c349",
    "--status-idle": "#908f9e",
    "--status-error": "#ffb4ab",
    "--status-stale": "#5a5a6b",
    "--status-ended": "#464653",
    "--border": "#ffffff",
    "--input": "#000080",
    "--ring": "#ffffff",
    "--primary": "#ffffff",
    "--primary-foreground": "#000080",
    "--secondary": "#c6c6c7",
    "--secondary-foreground": "#2f3131",
    "--card": "#000080",
    "--card-foreground": "#ffffff",
    "--popover": "#000080",
    "--popover-foreground": "#ffffff",
    "--destructive": "#ffb4ab",
    "--destructive-foreground": "#690005",
    "--sidebar": "#000000",
    "--sidebar-foreground": "#ffffff",
    "--sidebar-primary": "#ffffff",
    "--sidebar-primary-foreground": "#000000",
    "--sidebar-accent": "#000080",
    "--sidebar-accent-foreground": "#ffffff",
    "--sidebar-border": "#ffffff",
    "--sidebar-ring": "#ffffff"
  },
  "mascot_mode": "sprite",
  "mascot_sprite": {
    "cell": { "width": 20, "height": 24 },
    "padding": { "x": 8, "y": 8 },
    "gap": { "x": 12, "y": 8 },
    "rows": {
      "main": 0,
      "general": 0,
      "explorer": 1,
      "writer": 3,
      "code-reviewer": 4,
      "coder": 5
    },
    "states": {
      "idle":    { "frames": [0] },
      "running": { "frames": [0, 3], "fps": 6 },
      "waiting": { "frames": [4, 5] },
      "error":   { "frames": [8] }
    }
  }
}
