{
  "id": "super-mario-bros",
  "name": "Super Mario Bros.",
  "author": "agent-zoo",
  "tokens": {
    "--bg": "#fff8f7",
    "--fg": "#1a1a1a",
    "--muted": "#f4d3ce",
    "--muted-foreground": "#4a4a4a",
    "--accent": "#e52521",
    "--accent-foreground": "#fff8f7",
    "--accent-2": "#f8b800",
    "--status-running": "#00a651",
    "--status-waiting": "#f8b800",
    "--status-idle": "#9a9a9a",
    "--status-error": "#e52521",
    "--status-ended": "#5a5a5a",
    "--border": "#1a1a1a",
    "--input": "#fff8f7",
    "--ring": "#e52521",
    "--primary": "#e52521",
    "--primary-foreground": "#fff8f7",
    "--secondary": "#f4d3ce",
    "--secondary-foreground": "#1a1a1a",
    "--card": "#fff8f7",
    "--card-foreground": "#1a1a1a",
    "--popover": "#fff8f7",
    "--popover-foreground": "#1a1a1a",
    "--destructive": "#e52521",
    "--destructive-foreground": "#fff8f7",
    "--sidebar": "#d54d00",
    "--sidebar-foreground": "#ffcccc",
    "--sidebar-primary": "#f8b800",
    "--sidebar-primary-foreground": "#1a1a1a",
    "--sidebar-accent": "#a83c00",
    "--sidebar-accent-foreground": "#ffcccc",
    "--sidebar-border": "#a83c00",
    "--sidebar-ring": "#f8b800"
  },
  "mascot_mode": "sprite",
  "mascot_sprite": {
    "cell": { "width": 16, "height": 32 },
    "gap": { "x": 2, "y": 0 },
    "padding": { "x": 0, "y": 18 },
    "rows": {
      "main": 0,
      "general": 0,
      "explorer": 0,
      "writer": 0,
      "code-reviewer": 0,
      "coder": 0
    },
    "states": {
      "idle":    { "frames": [0] },
      "running": { "frames": [1, 2, 3], "fps": 6 },
      "waiting": { "frames": [6] },
      "error":   { "frames": [6] }
    }
  }
}
