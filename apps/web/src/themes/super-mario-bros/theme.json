{
  "id": "super-mario-bros",
  "name": "Super Mario Bros.",
  "author": "agent-zoo",
  "tokens": {
    "--bg": "#fff8f7",
    "--fg": "#291715",
    "--muted": "#f4d3ce",
    "--muted-foreground": "#5d3f3b",
    "--accent": "#e52521",
    "--accent-foreground": "#ffffff",
    "--accent-2": "#c9a900",
    "--status-running": "#4caf50",
    "--status-waiting": "#fff176",
    "--status-idle": "#d1d5db",
    "--status-error": "#e52521",
    "--status-ended": "#9c27b0",
    "--border": "#291715",
    "--input": "#fff0ee",
    "--ring": "#be000c",
    "--primary": "#be000c",
    "--primary-foreground": "#ffffff",
    "--secondary": "#8cfb87",
    "--secondary-foreground": "#00751b",
    "--card": "#ffffff",
    "--card-foreground": "#291715",
    "--popover": "#ffffff",
    "--popover-foreground": "#291715",
    "--destructive": "#ba1a1a",
    "--destructive-foreground": "#ffffff",
    "--sidebar": "#ffe9e6",
    "--sidebar-foreground": "#291715",
    "--sidebar-primary": "#be000c",
    "--sidebar-primary-foreground": "#ffffff",
    "--sidebar-accent": "#fddbd6",
    "--sidebar-accent-foreground": "#be000c",
    "--sidebar-border": "#291715",
    "--sidebar-ring": "#be000c"
  },
  "mascot_mode": "sprite",
  "mascot_sprite": {
    "cell": { "width": 16, "height": 32 },
    "gap": { "x": 2, "y": 0 },
    "padding": { "x": 0, "y": 18 },
    "rows": {
      "main": 0,
      "general": 0,
      "explorer": 0,
      "writer": 0,
      "code-reviewer": 0,
      "coder": 0
    },
    "states": {
      "idle":    { "frames": [0] },
      "running": { "frames": [1, 2, 3], "fps": 6 },
      "waiting": { "frames": [6] },
      "error":   { "frames": [6] },
      "ended":   { "frames": [5] }
    }
  }
}
